#: import datamodel libs.datamodel.datamodel

<Home>:
    CStackLayout:
        size_hint: [1, 1]
        padding: [dp(16), 0]

        CBoxLayout:
            adaptive: [False, False]
            spacing: dp(16)

            ScrollView:
                always_overscroll: False

                CGridLayout:
                    responsive: True
                    min_cols: 2
                    cols: 2
                    max_cols: 2
                    adaptive: [False, True]
                    spacing: dp(16)

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                # Two-way binding for strings
                                text: datamodel.android_package_name or ""
                                on_text: datamodel.android_package_name = self.text
                            CTextInputLabel:
                                text: "Package name"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "e.g. com.kivyschool.yourapp"

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                # Convert int to string for UI, convert back to int on save
                                text: str(datamodel.android_min_api or "")
                                on_text: datamodel.android_min_api = int(self.text) if self.text.isdigit() else None
                            CTextInputLabel:
                                text: "Minimum api version"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "recommended: 24"

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                text: str(datamodel.android_api or "")
                                on_text: datamodel.android_api = int(self.text) if self.text.isdigit() else None
                            CTextInputLabel:
                                text: "Maximum api version"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "recommended: 36"

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                text: datamodel.android_sdk or ""
                                on_text: datamodel.android_sdk = self.text
                            CTextInputLabel:
                                text: "Android sdk version"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "recommended: 36"

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                text: datamodel.android_ndk or ""
                                on_text: datamodel.android_ndk = self.text
                            CTextInputLabel:
                                text: "Android ndk version"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "recommended: 28c"

                    RoundedBoxLayout:
                        bg_color: app.layer_01
                        adaptive: [False, True]
                        padding: [dp(16), dp(32), dp(16), dp(32)]

                        CTextInputLayout:
                            CTextInput:
                                text: str(datamodel.android_ndk_api or "")
                                on_text: datamodel.android_ndk_api = int(self.text) if self.text.isdigit() else None
                            CTextInputLabel:
                                text: "Android ndk api version"
                                -color: app.text_primary
                                weight_style: "SemiBold"
                            CTextInputHelperText:
                                text: "recommended: =minapi=24"

            CDivider:
                orientation: "vertical"

            ScrollView:
                always_overscroll: False

                RightLayout:

<RightLayout@CBoxLayout>:
    adaptive: [False, True]
    orientation: "vertical"
    padding: [dp(2), 0]
    spacing: dp(16)

    CBoxLayout:
        adaptive: [True, True]
        padding: [0, dp(32)]

        CRadioGroupLayout:

            CRadioGroupLabel:
                text: "Android aarchs"
                style: "heading_02"
                -color: app.text_primary
                padding: [0, dp(8)]

            CRadioGroupHelperText:
                text: "Select x86_64 for emulator."

            CRadioGroup:
                id: group_master
                pos_hint: {"center_x": 0.5, "center_y": 0.5}
                size_hint_x: None
                width: dp(256)
                spacing: dp(8)

                CRadioItem:
                    CCheckbox:
                        pos_hint: {"center_y": 0.5}
                        active: "arm64-v8a" in [a.value for a in datamodel.android_archs] if datamodel.android_archs else False
                    CRadioButtonLabel:
                        text: "arm64-v8a"
                        pos_hint: {"center_y": 0.5}

                CRadioItem:
                    CCheckbox:
                        pos_hint: {"center_y": 0.5}
                        active: "x86_64" in [a.value for a in datamodel.android_archs] if datamodel.android_archs else False
                    CRadioButtonLabel:
                        text: "x86_64"
                        pos_hint: {"center_y": 0.5}
