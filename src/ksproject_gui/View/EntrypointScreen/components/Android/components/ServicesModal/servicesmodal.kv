<ServicesModal>:
    size_hint_y: 0.8
    width: dp(576)

    CModalLayout:
        id: modal_layout
        size_hint_y: 1

        CModalHeader:
            id: header

            CModalHeaderTitle:
                text: "Android Service"

        CModalBody:
            id: body
            size_hint: 1, 0.8
            padding: dp(16)

            CModalBodyContent:
                id: content
                text: "This is the services modal. You can add your services here."

            ScrollView:
                always_overscroll: False

                CBoxLayout:
                    adaptive: [False, True]
                    padding: [dp(16), dp(32), dp(16), dp(128)]
                    spacing: dp(64)
                    orientation: "vertical"

                    CTextInputLayout:
                        bg_color: app.layer_02
                        CTextInput:
                            hint_text: "MyService"
                        CTextInputLabel:
                            text: "Service name"
                            -color: app.text_primary
                            weight_style: "SemiBold"
                        CTextInputHelperText:
                            text: "e.g. MyService"

                    CBoxLayout:
                        adaptive: [False, True]
                        spacing: dp(16)

                        CLabelNeutral:
                            text: "Foreground"
                            style: "label_02"
                            size_hint_y: 1

                        CToggle:
                            id: foreground_toggle
                            role: "Small"

                    CTextInputLayout:
                        bg_color: app.layer_02
                        cstate: "normal" if foreground_toggle.active else "disabled"
                        CTextInput:
                            hint_text: "location|dataSync"
                        CTextInputLabel:
                            text: "Foreground service type"
                            -color: app.text_primary
                            weight_style: "SemiBold"
                        CTextInputHelperText:
                            text: "e.g. location|dataSync|mediaPlayback"

                    CTextInputLayout:
                        bg_color: app.layer_02
                        CTextInput:
                            text: "START_NOT_STICKY"
                            hint_text: "START_NOT_STICKY"
                            readonly: True
                        CTextInputLabel:
                            text: "Service start type"
                            -color: app.text_primary
                            weight_style: "SemiBold"
                        CTextInputTrailingIconButton:
                            id: start_type_dropdown_btn
                            icon: "chevron--down"
                            on_press:
                                root.launch_start_type_dropdown()
                        CTextInputHelperText:
                            text: "Select from dropdown"

                    CTextInputLayout:
                        bg_color: app.layer_02
                        CTextInput:
                            hint_text: "yourapp.services.myservice"
                        CTextInputLabel:
                            text: "Service entrypoint"
                            -color: app.text_primary
                            weight_style: "SemiBold"
                        CTextInputHelperText:
                            text: "Python file as a python module"

        CModalFooter:
            id: footer

            CGridLayout:
                cols: 2
                adaptive: [False, True]
                spacing: dp(1)

                CButtonSecondary:
                    text: "Cancel"
                    role: "Extra Large"
                    size_hint_x: 1
                    on_press:
                        root.dismiss()

                CButtonPrimary:
                    text: "Continue"
                    icon: "chevron--right"
                    role: "Extra Large"
                    size_hint_x: 1

    CModalCloseButton:

<StartTypeDropdown>:
    orientation: "vertical"
    padding: [dp(8), dp(32)]
    spacing: dp(32)
    width: dp(256)
    margin: dp(2)
    adaptive: [False, True]
    bg_color: app.layer_01

    CRadioGroupLayout:

        CRadioGroupLabel:
            text: "Radio button group"

        CRadioGroupHelperText:
            text: "Helper text"

        CRadioGroup:
            id: group_master
            size_hint_x: None
            width: dp(256)
            spacing: dp(16)

            CRadioItem:

                CRadioButton:
                    pos_hint: {"center_y": 0.5}
                    group_master: group_master

                CRadioButtonLabel:
                    text: "START_STICKY"
                    pos_hint: {"center_y": 0.5}

            CRadioItem:

                CRadioButton:
                    pos_hint: {"center_y": 0.5}
                    default: True
                    group_master: group_master

                CRadioButtonLabel:
                    text: "START_NOT_STICKY"
                    pos_hint: {"center_y": 0.5}

            CRadioItem:

                CRadioButton:
                    pos_hint: {"center_y": 0.5}
                    group_master: group_master

                CRadioButtonLabel:
                    text: "START_REDELIVER_INTENT"
                    pos_hint: {"center_y": 0.5}