<Permissions>:

    CBoxLayout:
        size_hint: [1, 1]
        orientation: "vertical"
        padding: [dp(16), 0]
        spacing: dp(16)

        CButtonPrimary:
            text: "Add permission"
            icon: "add--large"

        CStackLayout:
            spacing: dp(16)
            padding: [dp(2), 0]

            Permission:
                name: "INTERNET"

            Permission:
                name: "POST_NOTIFICATIONS"

            Permission:
                name: "ACCESS_NETWORK_STATE"


<Permission>:
    canvas.after:
        Color:
            rgba: app.interactive
        Line:
            width: dp(2)
            cap: "square"
            points: [self.x, self.y + dp(2), self.x, self.top - dp(2)]
    padding: [dp(16), dp(4), dp(4), dp(4)]
    bg_color: app.layer_01
    adaptive: [True, True]
    spacing: dp(16)

    CLabelNeutral:
        text: root.name
        size_hint_y: 1

    UIShellButton:
        variant: "Ghost"
        icon: "close"